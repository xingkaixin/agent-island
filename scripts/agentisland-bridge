#!/usr/bin/env python3
import json
import os
import socket
import subprocess
import sys
from errno import ECONNREFUSED, ECONNRESET, ENOENT, ENOTCONN, EPIPE
from datetime import datetime, timezone


def log_path():
    home = os.environ.get("HOME", "/tmp")
    return os.path.join(home, ".agentisland", "logs", "bridge.log")


def append_log(stage, payload):
    path = log_path()
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "a", encoding="utf-8") as handle:
        handle.write(
            json.dumps(
                {
                    "timestamp": datetime.now(timezone.utc).isoformat(),
                    "stage": stage,
                    "payload": payload,
                },
                ensure_ascii=False,
            )
            + "\n"
        )


def first_str(raw, paths, default):
    for path in paths:
        current = raw
        for segment in path:
            if not isinstance(current, dict) or segment not in current:
                current = None
                break
            current = current[segment]
        if isinstance(current, str) and current:
            return current
    return default


def socket_path():
    home = os.environ.get("HOME", "/tmp")
    return os.path.join(home, ".agentisland", "run", "agentisland.sock")


def should_ignore_ipc_error(error):
    return isinstance(error, FileNotFoundError) or (
        isinstance(error, OSError)
        and error.errno in {ENOENT, ECONNREFUSED, ECONNRESET, ENOTCONN, EPIPE}
    )


def read_process_table():
    result = subprocess.run(
        ["ps", "-axo", "pid=,ppid=,args="],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return {}

    processes = {}
    for line in result.stdout.splitlines():
        process = parse_process_line(line)
        if process is not None:
            processes[process["pid"]] = process
    return processes


def parse_process_line(line):
    trimmed = line.lstrip()
    if not trimmed:
        return None

    parts = trimmed.split(None, 2)
    if len(parts) != 3:
        return None

    try:
        pid = int(parts[0])
        ppid = int(parts[1])
    except ValueError:
        return None

    return {"pid": pid, "ppid": ppid, "args": parts[2]}


def bundle_path_from_args(args):
    marker = ".app/Contents/"
    index = args.find(marker)
    if index < 0:
        return None

    bundle = args[: index + 4]
    if not bundle.startswith("/"):
        return None
    return bundle


def app_name_from_bundle_path(bundle_path):
    name = os.path.basename(bundle_path)
    if not name.endswith(".app"):
        return None
    return name[:-4] or None


def detect_launcher():
    processes = read_process_table()
    current = processes.get(os.getpid())
    if current is None:
        return None

    parent_pid = current["ppid"]
    while parent_pid:
        process = processes.get(parent_pid)
        if process is None:
            return None

        bundle_path = bundle_path_from_args(process["args"])
        if bundle_path:
            name = app_name_from_bundle_path(bundle_path)
            if name:
                return {
                    "name": name,
                    "bundlePath": bundle_path,
                    "pid": process["pid"],
                    "detectedFrom": "processTree",
                }

        parent_pid = process["ppid"]
    return None


def main():
    args = sys.argv[1:]
    source = "unknown"
    for index, arg in enumerate(args[:-1]):
        if arg == "--source":
            source = args[index + 1]
            break

    raw_stdin = sys.stdin.read()
    raw = {}
    if raw_stdin.strip():
        raw = json.loads(raw_stdin)

    event = {
        "source": source,
        "sessionId": first_str(
            raw,
            [
                ["sessionId"],
                ["session_id"],
                ["conversationId"],
                ["conversation_id"],
                ["chatId"],
                ["chat_id"],
                ["payload", "sessionId"],
                ["payload", "session_id"],
            ],
            "unknown-session",
        ),
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "kind": first_str(
            raw,
            [
                ["hookEventName"],
                ["hook_event_name"],
                ["eventName"],
                ["event_name"],
                ["event"],
                ["kind"],
                ["type"],
                ["payload", "hookEventName"],
                ["payload", "hook_event_name"],
                ["payload", "eventName"],
                ["payload", "event"],
                ["payload", "kind"],
                ["payload", "type"],
            ],
            "unknown",
        ),
        "launcher": detect_launcher(),
        "payload": raw,
    }
    append_log("incoming", {"argv": sys.argv[1:], "raw": raw, "event": event})

    request = json.dumps({"event": event}).encode("utf-8")
    sock_path = socket_path()
    if not os.path.exists(sock_path):
        append_log("socket-missing", {"socketPath": sock_path})
        return

    client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        try:
            client.connect(sock_path)
            client.sendall(request)
            client.shutdown(socket.SHUT_WR)

            chunks = []
            while True:
                chunk = client.recv(65536)
                if not chunk:
                    break
                chunks.append(chunk)
        except Exception as error:
            if should_ignore_ipc_error(error):
                append_log(
                    "ipc-unavailable",
                    {"socketPath": sock_path, "message": str(error)},
                )
                return
            raise
    finally:
        client.close()

    raw_response = b"".join(chunks).decode("utf-8").strip()
    if not raw_response:
        return

    response = json.loads(raw_response)
    append_log("response", response)
    if not response.get("ok"):
        print(response.get("error", "ipc request failed"), file=sys.stderr)
        sys.exit(1)

    decision = response.get("decision")
    if decision is not None:
        sys.stdout.write(json.dumps(decision))


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        append_log("error", {"message": str(error)})
        print(f"agentisland-bridge: {error}", file=sys.stderr)
        sys.exit(1)
